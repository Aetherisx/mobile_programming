<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button android:id="@+id/sensor1_button" android:layout_width="250dp" android:layout_height="50dp" android:layout_margin="8dp" android:text="Accelerometer Sensor" />
        <Button android:id="@+id/sensor2_button" android:layout_width="250dp" android:layout_height="50dp" android:layout_margin="8dp" android:text="Compass Sensor" />
        <Button android:id="@+id/sensor3_button" android:layout_width="250dp" android:layout_height="50dp" android:layout_margin="8dp" android:text="Gyroscope Sensor" />
        <Button android:id="@+id/sensor4_button" android:layout_width="250dp" android:layout_height="50dp" android:layout_margin="8dp" android:text="Humidity Sensor" />
        <Button android:id="@+id/sensor5_button" android:layout_width="250dp" android:layout_height="50dp" android:layout_margin="8dp" android:text="Light Sensor" />
        <Button android:id="@+id/sensor6_button" android:layout_width="250dp" android:layout_height="50dp" android:layout_margin="8dp" android:text="Magnetometer Sensor" />
        <Button android:id="@+id/sensor7_button" android:layout_width="250dp" android:layout_height="50dp" android:layout_margin="8dp" android:text="Pressure Sensor" />
        <Button android:id="@+id/sensor8_button" android:layout_width="250dp" android:layout_height="50dp" android:layout_margin="8dp" android:text="Proximity Sensor" />
        <Button android:id="@+id/sensor9_button" android:layout_width="250dp" android:layout_height="50dp" android:layout_margin="8dp" android:text="Thermometer Sensor" />

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>